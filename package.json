{
  "name": "p2pbuilders",
  "version": "0.0.1",
  "description": "Permissionless P2P messageboard on the Pear/Bare stack",
  "main": "src/terminal/main.js",
  "type": "commonjs",
  "imports": {
    "#fs": {
      "bare": "bare-fs",
      "default": "./src/backend/_node-fs.js"
    },
    "#path": {
      "bare": "bare-path",
      "default": "./src/backend/_node-path.js"
    },
    "#os": {
      "bare": "bare-os",
      "default": "./src/backend/_node-os.js"
    },
    "#env": {
      "bare": "bare-env",
      "default": "./src/backend/_node-env.js"
    },
    "#events": {
      "bare": "bare-events",
      "default": "./src/backend/_node-events.js"
    },
    "#process": {
      "bare": "bare-process",
      "default": "./src/backend/_node-process.js"
    }
  },
  "scripts": {
    "start": "node src/backend/server.js",
    "dev": "P2PBUILDERS_NO_SWARM=1 P2PBUILDERS_DIR=./.data P2PBUILDERS_PORT=8787 node src/backend/server.js",
    "pear": "pear run -d . --dev",
    "pear:stage": "pear stage dev .",
    "relay": "node src/relay/server.js",
    "publish": "node scripts/publish.js",
    "test": "node test/m1.js && node test/m2.js && node test/m3.js && node test/m4.js && node test/m5.js && node test/m6.js && node test/m7.js && node test/m8.js && node test/m9.js && node test/m10-bare.js && node test/m11.js"
  },
  "pear": {
    "name": "p2pbuilders",
    "type": "terminal",
    "main": "src/terminal/main.js"
  },
  "dependencies": {
    "@hyperswarm/dht-relay": "^0.4.3",
    "b4a": "^1.6.6",
    "bare-env": "^3.0.0",
    "bare-fs": "^4.7.1",
    "bare-ipc": "^1.1.1",
    "bare-os": "^3.8.7",
    "bare-path": "^3.0.0",
    "bare-process": "^4.4.1",
    "bare-readline": "^1.3.1",
    "bare-tty": "^5.1.0",
    "compact-encoding": "^2.15.0",
    "corestore": "^7.0.0",
    "hyperbee": "^2.27.3",
    "hypercore": "^11.0.0",
    "hyperdht": "^6.30.0",
    "hyperswarm": "^4.17.0",
    "p2p-hiverelay": "^0.4.2",
    "pear-electron": "^1.7.28",
    "random-access-memory": "^6.2.1",
    "sodium-universal": "^5.0.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "bare": "^1.28.4",
    "bare-pack": "^2.0.1"
  }
}
